#! 排除 Git 版本控制資訊
.git
.gitignore

#! 排除 Python 快取與虛擬環境 (映像檔內應重新安裝)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/

#! 排除環境變數與機敏金鑰 (改由 Docker Compose 或 Secret 管理)
.env
.env.*

#! 排除 IDE 與開發設定
.vscode/
.idea/
*.swp

#! 排除資料庫與大型檔案 (避免映像檔肥大)
*.sqlite3
db.sqlite3
*.tar
*.zip
*.gz
*.log
logs/

#! 排除 Docker 設定檔案本身
Dockerfile
docker-compose*.yml
.dockerignore

#! 排除說明文件 (選配)
README.md
LICENSE