# ==============================================================================
# CSI Portal - 環境變數設定範本 (.env.example)
# 使用方法：請複製此檔案並改名為 `.env`，然後根據您的本地開發環境填入對應的數值。
# ==============================================================================

# ----------------------------------------------------
# 1. Django 核心設定
# ----------------------------------------------------
# Django 的安全密鑰 (生產環境下請務必更換，勿使用此預設值)
# 提示: 可以使用 python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())" 產生
SECRET_KEY=django-insecure-your-secret-key-here-change-me

# 開發模式開關 (True 為開發模式，False 為生產部署模式)
DEBUG=True

# 允許存取的網域 (多個網域用半形逗號隔開)
ALLOWED_HOSTS=*

# 信任的 CSRF 來源網域 (使用 ngrok 時，必須將 ngrok 產生的 https 網址填入此處)
CSRF_TRUSTED_ORIGINS=https://your-ngrok-subdomain.ngrok-free.app

# ----------------------------------------------------
# 2. 資料庫連線設定 (MySQL)
# ----------------------------------------------------
# 格式: mysql://使用者名稱:密碼@主機:埠號/資料庫名稱
DATABASE_URL=mysql://root:your_mysql_password@localhost:3306/csi_db

# ----------------------------------------------------
# 3. Google OAuth 2.0 登入憑證 (Google Fit 同步所需)
# ----------------------------------------------------
# 請在 Google Cloud Console (APIs & Services > Credentials) 申請
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----------------------------------------------------
# 4. LINE Bot 官方帳號與 LIFF 設定
# ----------------------------------------------------
# 請在 LINE Developers Console 中獲取：
# Channel Secret (在 Basic Settings 頁面)
LINE_CHANNEL_SECRET=your-line-channel-secret

# Channel Access Token (在 Messaging API 頁面，請點選 Issue 產生長效 Token)
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# LINE LIFF ID (在 LIFF 頁面建立 LIFF 應用程式後取得)
LINE_LIFF_ID=your-line-liff-id

# LINE 系統維護模式切換 (True 會顯示維護中畫面，False 為正常開啟)
LINE_MAINTENANCE_MODE=False

# ----------------------------------------------------
# 5. 資料庫欄位加密金鑰 (Fernet Key)
# ----------------------------------------------------
# 用於加密劇名、行程連結等機密資料。必須為 32 位元 Base64 安全密鑰！
# 產生指令: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-encryption-key-here

# ----------------------------------------------------
# 6. 其他第三方 API 與服務設定
# ----------------------------------------------------
# NGROK 自動驗證 Token (用於快速開啟內網穿透轉發)
NGROK_AUTHTOKEN=your-ngrok-authtoken

# Gmail 寄信帳號 (SMTP 驗證)
EMAIL_USER=your-gmail-account@gmail.com
# Gmail 應用程式專用密碼 (請在 Google 帳號安全設定中開啟「應用程式密碼」)
EMAIL_PASS=your-gmail-app-password-16-chars

# Gemini AI 服務金鑰 (若有使用 LLM 對話功能)
GEMINI_API_KEY=your-gemini-api-key

# 本地 LLM GGUF 模型檔案的絕對路徑
LLM_MODEL_PATH=d:/path/to/your/Qwen2.5-1.5B-Instruct-Q4_K_M.gguf

# ----------------------------------------------------
# 7. 綠界支付 (ECPay) 商店資訊(測試版商店)
# ----------------------------------------------------
MERCHANT_ID=3002607
HASH_KEY=pwFHCqoQZGmho4w6
HASH_IV=EkRm7iFT261dpevs

# ----------------------------------------------------
# 8. 專案內部特定變數
# ----------------------------------------------------
DISPATCH_WORD=XXX
CSI_EMAIL=@XXX
